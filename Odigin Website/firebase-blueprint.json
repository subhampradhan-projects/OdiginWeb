{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with persistent state",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Cart": {
      "title": "Cart",
      "description": "Omnichannel persistent shopping cart",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer products reviews and social proof",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "images": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "total", "status", "items"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public user profiles"
    },
    "/carts/{userId}": {
      "schema": "Cart",
      "description": "User persistent shopping carts"
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product-specific reviews"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer order history"
    }
  }
}
